{
    "name": "magick-wasm-docs",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "run-p type-check \"build-only {@}\" && cpy ./dist/index.html . --rename 404.html",
